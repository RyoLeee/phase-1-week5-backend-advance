<%- include('../partials/header.ejs', { title: 'Dashboard - ChatPlatform' }) %>

<div class="dashboard">
  <div class="dashboard-header">
    <h1>Chat Rooms</h1>
    <button class="btn btn-primary" onclick="openCreateModal()">+ Create Room</button>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('all', this)">All Rooms</button>
    <button class="tab" onclick="switchTab('mine', this)">My Rooms</button>
  </div>

  <div id="alertBox" class="alert hidden"></div>

  <div id="allRooms" class="room-grid">
    <% if (rooms && rooms.length > 0) { %>
      <% rooms.forEach(room => { %>
        <div class="room-card" data-room-id="<%= room.id %>" data-owner-id="<%= room.ownerId %>">
          <div class="room-card-header">
            <div class="room-icon">🏠</div>
            <div class="room-actions">
              <span class="delete-btn hidden" onclick="deleteRoom('<%= room.id %>', '<%= room.name %>')">🗑️</span>
            </div>
          </div>
          <h4><%= room.name %></h4>
          <p class="room-desc"><%= room.description || 'No description' %></p>
          <div class="room-meta">
            <span class="room-owner">👤 <%= room.ownerUsername %></span>
            <span class="room-privacy"><%= room.isPrivate ? '🔒 Private' : '🌐 Public' %></span>
          </div>
          <a href="/chat/<%= room.id %>" class="btn btn-primary btn-sm btn-full">Join Room</a>
        </div>
      <% }) %>
    <% } else { %>
      <div class="empty-state">
        <span class="empty-icon">🏠</span>
        <p>No rooms yet. Create the first one!</p>
      </div>
    <% } %>
  </div>

  <div id="myRooms" class="room-grid hidden">
    <div class="loading">Loading your rooms...</div>
  </div>
</div>

<!-- Create Room Modal -->
<div id="createModal" class="modal hidden">
  <div class="modal-overlay" onclick="closeCreateModal()"></div>
  <div class="modal-content">
    <div class="modal-header">
      <h3>Create New Room</h3>
      <button class="modal-close" onclick="closeCreateModal()">×</button>
    </div>
    <form id="createRoomForm">
      <div class="form-group">
        <label>Room Name *</label>
        <input type="text" id="roomName" placeholder="e.g., general, tech-talk" required maxlength="50">
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" id="roomDesc" placeholder="What's this room about?" maxlength="200">
      </div>
      <div class="form-group checkbox-group">
        <input type="checkbox" id="isPrivate">
        <label for="isPrivate">🔒 Private room</label>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="closeCreateModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="createBtn">Create Room</button>
      </div>
    </form>
  </div>
</div>

<script>
const token = localStorage.getItem('token');
const currentUser = JSON.parse(localStorage.getItem('user') || 'null');

// Mark delete buttons for user's rooms
document.querySelectorAll('.room-card').forEach(card => {
  if (currentUser && card.dataset.ownerId === currentUser.id) {
    card.querySelector('.delete-btn').classList.remove('hidden');
  }
});

// Tabs
function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');

  if (tab === 'all') {
    document.getElementById('allRooms').classList.remove('hidden');
    document.getElementById('myRooms').classList.add('hidden');
  } else {
    document.getElementById('allRooms').classList.add('hidden');
    document.getElementById('myRooms').classList.remove('hidden');
    loadMyRooms();
  }
}

async function loadMyRooms() {
  if (!token) {
    document.getElementById('myRooms').innerHTML = '<div class="empty-state"><p>Please <a href="/login">login</a> to see your rooms.</p></div>';
    return;
  }

  const res = await fetch('/api/rooms/user/mine', {
    headers: { 'Authorization': `Bearer ${token}` }
  });
  const data = await res.json();
  const container = document.getElementById('myRooms');

  if (!data.success || !data.data.length) {
    container.innerHTML = '<div class="empty-state"><span class="empty-icon">🏠</span><p>You haven\'t joined any rooms yet.</p></div>';
    return;
  }

  container.innerHTML = data.data.map(room => `
    <div class="room-card">
      <div class="room-card-header">
        <div class="room-icon">🏠</div>
        <div class="room-actions">
          ${room.ownerId === currentUser?.id ? `<span class="delete-btn" onclick="deleteRoom('${room.id}', '${room.name}')">🗑️</span>` : ''}
        </div>
      </div>
      <h4>${room.name}</h4>
      <p class="room-desc">${room.description || 'No description'}</p>
      <div class="room-meta">
        <span class="room-owner">👤 ${room.ownerUsername}</span>
        <span class="role-badge">${room.role}</span>
      </div>
      <a href="/chat/${room.id}" class="btn btn-primary btn-sm btn-full">Open Room</a>
    </div>
  `).join('');
}

// Create room
function openCreateModal() {
  if (!token) return window.location.href = '/login';
  document.getElementById('createModal').classList.remove('hidden');
}

function closeCreateModal() {
  document.getElementById('createModal').classList.add('hidden');
}

document.getElementById('createRoomForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('createBtn');
  btn.disabled = true;
  btn.textContent = 'Creating...';

  const name = document.getElementById('roomName').value;
  const description = document.getElementById('roomDesc').value;
  const isPrivate = document.getElementById('isPrivate').checked;

  try {
    const res = await fetch('/api/rooms', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      },
      body: JSON.stringify({ name, description, isPrivate })
    });
    const data = await res.json();

    if (data.success) {
      window.location.href = `/chat/${data.data.id}`;
    } else {
      showAlert(data.error, 'error');
    }
  } catch {
    showAlert('Failed to create room', 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Create Room';
  }
});

// Delete room
async function deleteRoom(roomId, roomName) {
  if (!confirm(`Delete room "${roomName}"? This cannot be undone.`)) return;

  try {
    const res = await fetch(`/api/rooms/${roomId}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await res.json();

    if (data.success) {
      showAlert('Room deleted', 'success');
      setTimeout(() => window.location.reload(), 1000);
    } else {
      showAlert(data.error, 'error');
    }
  } catch {
    showAlert('Failed to delete room', 'error');
  }
}

function showAlert(msg, type) {
  const box = document.getElementById('alertBox');
  box.textContent = msg;
  box.className = `alert alert-${type}`;
  setTimeout(() => box.className = 'alert hidden', 4000);
}
</script>

<%- include('../partials/footer.ejs') %>
